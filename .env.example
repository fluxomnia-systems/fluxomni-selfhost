# FluxOmni split runtime image repositories
FLUXOMNI_CONTROL_PLANE_IMAGE=ghcr.io/fluxomnia-systems/fluxomni-control-plane
FLUXOMNI_MEDIA_NODE_IMAGE=ghcr.io/fluxomnia-systems/fluxomni-media-node

# Shared image tag (for example: latest, edge, vX.Y.Z)
FLUXOMNI_VERSION=latest

# Public hosts or IPs advertised to operators and publishing clients
FLUXOMNI_PUBLIC_HOST=127.0.0.1
FLUXOMNI_MEDIA_NODE_PUBLIC_HOST=127.0.0.1

# Shared auth token between control-plane and media-node.
# The installer generates this automatically; set a random value for manual installs.
FLUXOMNI_CONTROL_PLANE_INTERNAL_AUTH_TOKEN=replace-me

# Host port bindings
FLUXOMNI_CONTROL_PLANE_HTTP_PORT=80
FLUXOMNI_CONTROL_PLANE_RPC_PORT=50052
FLUXOMNI_MEDIA_NODE_RTMP_PORT=1935
FLUXOMNI_MEDIA_NODE_HLS_PORT=8000
FLUXOMNI_MEDIA_NODE_SRT_PORT=10080
FLUXOMNI_MEDIA_NODE_GRPC_PORT=50051

# Single-host storage layout. Keep both app roots on ./data unless you are
# intentionally separating the media-node filesystem.
FLUXOMNI_CONTROL_PLANE_DATA_DIR=./data
FLUXOMNI_MEDIA_NODE_DATA_DIR=./data
FLUXOMNI_SHARED_VIDEO_DIR=./data/videos

# Standalone media-node installs require these values. The installer writes
# them automatically when run in media-node mode.
# FLUXOMNI_CONTROL_PLANE_RPC_ENDPOINT=http://control-plane.example.internal:50052
# FLUXOMNI_MEDIA_NODE_ENDPOINT=http://media-node.example.internal:50051

# Optional runtime variables (uncomment if needed)
# FLUXOMNI_OTLP_ENDPOINT=http://collector.example.internal:4318
# FLUXOMNI_MEDIA_NODE_ID=media-node-1
# FLUXOMNI_MEDIA_NODE_NAME=Media Node 1
