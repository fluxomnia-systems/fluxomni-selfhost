# FluxOmni container image repository
FLUXOMNI_IMAGE=ghcr.io/fluxomnia-systems/fluxomni

# FluxOmni image tag (for example: edge, latest, 0.8.0)
FLUXOMNI_VERSION=edge

# Public host or IP advertised to clients
FLUXOMNI_PUBLIC_HOST=127.0.0.1

# Optional runtime variables (uncomment if needed)
# PASSWORD_HASH=$argon2id$...
# ALLOWED_IPS=*
# FLUXOMNI_OTLP_COLLECTOR_IP=
# FLUXOMNI_OTLP_COLLECTOR_PORT=
# FLUXOMNI_SERVICE_NAME=fluxomni
